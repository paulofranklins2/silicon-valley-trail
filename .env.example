# Silicon Valley Trail

# No API keys required. All 4 game modes work out of the box.
# Open-Meteo (weather) and OSRM (driving distance) are free and keyless.

# Database
# Default: H2 in-memory (zero setup).
# To use Postgres, set these env vars:
# (or run docker-compose.yml for a local Postgres instance)

# DB_URL=jdbc:postgresql://localhost:5432/svt
# DB_USERNAME=root
# DB_PASSWORD=root

# OpenRouteService API key (optional)
# Acts as fallback for Road mode if OSRM is unavailable.
# Get a free key at https://openrouteservice.org/dev/#/signup

# ORS_API_KEY=your_key_here

# Weather mode (change in application.yml)
# Options: api, mock, demo