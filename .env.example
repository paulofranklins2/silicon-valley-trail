# Silicon Valley Trail

# No API keys required.
# Uses Open-Meteo (weather) and OSRM (routing), both keyless.

# Database
# Default: H2 in-memory (zero setup).
# To use Postgres, configure the following env vars:

# If you don't have Postgres locally, use docker-compose.yml
# (defaults: port 5432, db svt, user root, password root)

# DB_URL=jdbc:postgresql://localhost:5432/svt
# DB_USERNAME=root
# DB_PASSWORD=root

# Weather mode
# Default: api
# Options: api, mock, demo
# Change in application.yml for testing